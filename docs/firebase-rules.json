{
  "rules": {
    ".read": false,
    ".write": false,
    "rooms": {
      "main": {
        "players": {
          ".read": true,
          "$uid": {
            ".write": true,
            ".validate": "newData.child('name').isString() && newData.child('name').val().length <= 24 && newData.child('x').isNumber() && newData.child('y').isNumber()"
          }
        },
        "chat": {
          ".read": true,
          ".indexOn": "ts",
          "$msg": {
            ".write": "!data.exists()",
            ".validate": "newData.child('text').isString() && newData.child('text').val().length <= 200 && newData.child('name').isString()"
          }
        },
        "duels": {
          ".read": true,
          ".indexOn": "ts",
          "$id": {
            ".write": true,
            ".validate": "newData.child('a').isString() && newData.child('b').isString() && newData.child('status').isString()"
          }
        }
      }
    },
    "leaderboard": {
      ".read": true,
      "$uid": {
        ".write": true,
        ".validate": "newData.child('name').isString() && newData.child('name').val().length <= 24 && newData.child('points').isNumber() && newData.child('points').val() >= 0 && newData.child('points').val() <= 1000000"
      }
    },
    "homes": {
      ".read": true,
      "$uid": {
        ".write": true,
        ".validate": "newData.child('name').isString() && newData.child('name').val().length <= 24 && newData.child('spent').isNumber() && newData.child('spent').val() >= 0"
      }
    }
  }
}
